---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Desktop shows each site in a scaled-down live iframe; mobile swaps in a
// looping screen recording (or a still) since the iframes don't behave there.
const websiteDemos = [
  {
    id: 5,
    name: 'LegacyTape',
    url: 'https://mylegacytape.com/',
    description: 'Our own product: a recording device for family stories',
    tag: 'Our product',
    type: 'website',
  },
  {
    id: 1,
    name: 'The White Squirrel',
    url: 'https://www.thewhitesquirrelllc.com/',
    description: 'Gift shop in Oberlin, Ohio',
    tag: 'Website',
    type: 'website',
  },
  {
    id: 2,
    name: "Captain Fripp's Lost Treasures",
    url: 'https://apps.apple.com/us/app/captain-fripps-lost-treasures/id6752260563',
    description: 'Recreation app for Fripp Island, South Carolina',
    tag: 'iOS app',
    type: 'app',
  },
  {
    id: 3,
    name: 'Demo Grill',
    url: 'https://demo-grill.pages.dev/',
    description: 'Restaurant site with online ordering',
    tag: 'Demo build',
    type: 'website',
  },
  {
    id: 4,
    name: 'CLOTH',
    url: 'https://clothlandingdemo.pages.dev/',
    description: 'Streetwear storefront',
    tag: 'Demo build',
    type: 'website',
  },
];
---

<Layout title="Recent Work | FutureClarity Technologies">
  <Header />

  <!-- Intro -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 pb-14 pt-36 md:pb-20 md:pt-44">
      <p class="eyebrow mb-6">Portfolio</p>
      <h1 class="max-w-3xl text-4xl font-semibold leading-[1.08] tracking-tight sm:text-5xl">
        Recent work.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-soft">
        Client projects, demo builds, and our own product. The demos are real, working sites we
        made to show restaurant and shop owners what they could have, so click around and kick
        the tires.
      </p>
    </div>
  </section>

  <!-- Demos -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-14 md:py-20">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {
          websiteDemos.map((demo) => (
            <div class="flex flex-col border border-line bg-card">
              <div class="border-b border-line px-5 py-4">
                <div class="flex items-baseline justify-between gap-4">
                  <h2 class="font-display text-xl font-medium">{demo.name}</h2>
                  <span class="shrink-0 font-mono text-xs uppercase tracking-[0.15em] text-faint">{demo.tag}</span>
                </div>
                <p class="mt-0.5 text-sm text-soft">{demo.description}</p>
              </div>

              {demo.type === 'app' ? (
                <!-- App Store listing -->
                <div class="relative bg-paper" style="padding-bottom: 75%; height: 0; overflow: hidden;">
                  <div class="absolute inset-0 flex flex-col items-center justify-center p-6">
                    <div class="h-32 w-32 overflow-hidden rounded-[22%] border border-line shadow-sm sm:h-36 sm:w-36">
                      <img
                        src="/captain-fripp-icon.png"
                        alt="Captain Fripp's Lost Treasures app icon"
                        class="h-full w-full object-cover"
                      />
                    </div>
                    <p class="mt-5 text-sm text-soft">Available on the App Store</p>
                  </div>
                  <a
                    href={demo.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="absolute inset-0 z-10 h-full w-full"
                    title={`View ${demo.name} on the App Store`}
                    aria-label={`View ${demo.name} on the App Store`}
                  />
                </div>
              ) : (
                <>
                  <!-- Desktop: scaled live iframe with a loading state -->
                  <div class="iframe-container relative hidden md:block" style="padding-bottom: 75%; height: 0; overflow: hidden; background: var(--color-paper);">
                    <div id={`loading-${demo.id}`} class="absolute inset-0 flex h-full w-full items-center justify-center bg-paper">
                      <div class="text-center">
                        <div class="mx-auto mb-3 h-10 w-10 animate-spin rounded-full border-2 border-line border-t-ink" />
                        <p class="font-mono text-xs uppercase tracking-[0.15em] text-faint">Loading preview</p>
                      </div>
                    </div>

                    <iframe
                      id={`iframe-${demo.id}`}
                      src={demo.url}
                      class="absolute left-0 top-0 h-full w-full border-0 opacity-0 transition-opacity duration-500"
                      title={`${demo.name} website preview`}
                      loading="lazy"
                      sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
                      style="transform: scale(0.5); transform-origin: top left; width: 200%; height: 200%; pointer-events: none; overflow: hidden; min-width: 1200px;"
                      scrolling="no"
                      onload={`setTimeout(() => { document.getElementById('loading-${demo.id}').style.display = 'none'; document.getElementById('iframe-${demo.id}').style.opacity = '1'; }, 2000);`}
                    />

                    <a
                      href={demo.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="absolute inset-0 z-10 h-full w-full"
                      title={`Visit ${demo.name}`}
                      aria-label={`Visit ${demo.name}`}
                    />
                  </div>

                  <!-- Mobile: screen recording or still image -->
                  <div class="relative md:hidden" style="padding-bottom: 75%; height: 0; overflow: hidden; background: var(--color-paper);">
                    {demo.name === 'Demo Grill' ? (
                      <video class="absolute left-0 top-0 h-full w-full object-cover object-top" poster="/work/demo-grill.jpg" autoplay muted loop playsinline preload="metadata">
                        <source src="/DEMOGRILLloopMObile_compressed.mp4" type="video/mp4" />
                      </video>
                    ) : demo.name === 'CLOTH' ? (
                      <video class="absolute left-0 top-0 h-full w-full object-cover object-top" poster="/work/cloth.jpg" autoplay muted loop playsinline preload="metadata">
                        <source src="/ClOTHMOBILEVIDEO.mp4" type="video/mp4" />
                      </video>
                    ) : demo.name === 'The White Squirrel' ? (
                      <img
                        src="/Whitesquirrel.png"
                        alt={`${demo.name} website`}
                        class="absolute left-0 top-0 h-full w-full object-cover object-top"
                        loading="lazy"
                      />
                    ) : demo.name === 'LegacyTape' ? (
                      <img
                        src="/work/legacytape.jpg"
                        alt="The LegacyTape recorder prototype next to its companion app"
                        class="absolute left-0 top-0 h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="absolute inset-0 flex h-full w-full items-center justify-center bg-paper">
                        <p class="font-mono text-xs uppercase tracking-[0.15em] text-faint">Preview</p>
                      </div>
                    )}

                    <a
                      href={demo.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="absolute inset-0 z-10 h-full w-full"
                      title={`Visit ${demo.name}`}
                      aria-label={`Visit ${demo.name}`}
                    />
                  </div>
                </>
              )}

              <div class="mt-auto border-t border-line px-5 py-4">
                <a href={demo.url} target="_blank" rel="noopener noreferrer" class="link text-sm">
                  {demo.type === 'app' ? 'View on the App Store ↗' : 'Visit the live site ↗'}
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing note -->
  <section>
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">Have a project in mind?</h2>
        <p class="mt-4 text-soft">
          Tell us what you're after and we'll let you know what it would take. If we're not the
          right fit, we'll say so.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-6">
          <a href="/?scroll=contact" class="btn">Get in touch</a>
          <a href="/" class="link">Back to the homepage</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // If an embedded site never fires load (some sites refuse to be framed),
    // don't leave the spinner running forever.
    setTimeout(() => {
      document.querySelectorAll('[id^="loading-"]').forEach((el) => {
        (el as HTMLElement).style.display = 'none';
      });
      document.querySelectorAll('[id^="iframe-"]').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
      });
    }, 8000);
  </script>
</Layout>
