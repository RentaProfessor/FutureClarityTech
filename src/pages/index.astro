---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Workbench from '../components/Workbench.astro';
import Cassette from '../components/Cassette.astro';

const work = [
  {
    name: 'The White Squirrel',
    url: 'https://www.thewhitesquirrelllc.com/',
    blurb: 'Gift shop in Oberlin, Ohio',
    tag: 'Website',
    preview: '/work/white-squirrel.jpg',
    fit: 'cover',
  },
  {
    name: "Captain Fripp's Lost Treasures",
    url: 'https://apps.apple.com/us/app/captain-fripps-lost-treasures/id6752260563',
    blurb: 'Recreation app for Fripp Island, South Carolina',
    tag: 'iOS app',
    preview: '/captain-fripp-icon.png',
    fit: 'contain',
  },
  {
    name: 'Demo Grill',
    url: 'https://demo-grill.pages.dev/',
    blurb: 'Restaurant site with online ordering',
    tag: 'Demo build',
    preview: '/work/demo-grill.jpg',
    fit: 'cover',
  },
  {
    name: 'CLOTH',
    url: 'https://clothlandingdemo.pages.dev/',
    blurb: 'Streetwear storefront',
    tag: 'Demo build',
    preview: '/work/cloth.jpg',
    fit: 'cover',
  },
];

const steps = [
  {
    n: '1',
    title: 'Consultation',
    body: 'We talk through what you need, your timeline, and your budget. Then we collect your content, branding, and anything else the build depends on.',
  },
  {
    n: '2',
    title: 'Demo',
    body: 'We build a working demo of your actual site, not a mockup, so you can react to something real before the full build starts.',
  },
  {
    n: '3',
    title: 'Build',
    body: 'We build the full site to the spec we agreed on, and keep you posted as it comes together.',
  },
  {
    n: '4',
    title: 'Review & testing',
    body: 'You review the finished site, we make the final fixes, and we test everything on real phones and browsers.',
  },
  {
    n: '5',
    title: 'Launch',
    body: 'We connect your existing domain or register a new one, set up hosting, and hand everything over.',
  },
];
---

<Layout title="FutureClarity Technologies | Web development that just works.">
  <Header />

  <!-- Hero -->
  <section class="overflow-hidden border-b border-line">
    <div class="mx-auto grid max-w-6xl items-center gap-14 px-6 pb-16 pt-32 md:pb-24 md:pt-44 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="eyebrow mb-6" data-reveal>Websites, apps, and hardware</p>
        <h1
          class="max-w-2xl text-[2.6rem] font-semibold leading-[1.06] tracking-tight sm:text-5xl md:text-6xl"
          data-reveal
          style="--reveal-delay: 0.06s"
        >
          Web development that
          <span class="relative inline-block whitespace-nowrap"
            >just works.
            <svg class="hero-underline" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
              <path
                d="M4,9 C58,3 104,12 158,7 C212,2 262,11 316,5"
                fill="none"
                stroke="var(--color-accent)"
                stroke-width="5"
                stroke-linecap="round"
                pathLength="1"></path>
            </svg>
          </span>
        </h1>
        <p class="mt-7 max-w-xl text-lg text-soft" data-reveal style="--reveal-delay: 0.12s">
          FutureClarity is a small studio. We design and build websites and apps for small
          businesses, and we prototype products of our own. Either way, you deal directly with
          the people doing the work.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-6" data-reveal style="--reveal-delay: 0.18s">
          <a href="#contact" class="btn">Start a project</a>
          <a href="/portfolio" class="link">See recent work</a>
        </div>
        <p
          class="mt-8 flex items-center gap-2.5 font-mono text-xs uppercase tracking-[0.15em] text-soft"
          data-reveal
          style="--reveal-delay: 0.24s"
        >
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <g stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round">
              <path d="M7,1.5 L7,12.5"></path>
              <path d="M2,4.2 L12,9.8"></path>
              <path d="M12,4.2 L2,9.8"></path>
            </g>
          </svg>
          Taking on new projects
        </p>
      </div>
      <div class="hidden w-full lg:block" data-reveal style="--reveal-delay: 0.15s">
        <Workbench />
      </div>
    </div>
  </section>

  <!-- Recent work -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="flex items-baseline justify-between" data-reveal>
        <p class="eyebrow">Recent work</p>
        <a href="/portfolio" class="link text-sm">All work</a>
      </div>
      <ul class="mt-8 divide-y divide-line border-y border-line" data-reveal style="--reveal-delay: 0.08s">
        {
          work.map((item) => (
            <li>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                data-preview={item.preview}
                data-fit={item.fit}
                class="group flex flex-col gap-1 py-5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6"
              >
                <span>
                  <span class="font-display text-xl font-medium text-ink transition-colors group-hover:text-accent">
                    {item.name}
                  </span>
                  <span class="mt-0.5 block text-sm text-soft">{item.blurb}</span>
                </span>
                <span class="shrink-0 font-mono text-xs uppercase tracking-[0.15em] text-faint transition-colors group-hover:text-accent">
                  {item.tag} ↗
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- floating image that trails the cursor over the work list -->
  <div id="work-preview" aria-hidden="true"><img src="/work/white-squirrel.jpg" alt="" /></div>

  <!-- LegacyTape -->
  <section id="legacytape" class="scroll-mt-24 border-b border-line">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-16 md:grid-cols-[0.9fr_1.1fr] md:gap-16 md:py-24">
      <div class="hidden w-full md:block" data-reveal style="--reveal-delay: 0.1s">
        <Cassette />
      </div>
      <div data-reveal>
        <p class="eyebrow">From the workshop</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
          We build products of our own too.
        </h2>
        <div class="mx-auto mb-2 mt-8 w-full max-w-[270px] md:hidden">
          <Cassette />
        </div>
        <p class="mt-4 text-soft">
          LegacyTape is a retro-inspired recording device, paired with a companion app, that
          helps grandparents tell their life stories. Guided prompts walk them through each
          recording session, and the stories come back as a printed book the whole family keeps.
        </p>
        <p class="mt-4 text-soft">
          We're prototyping the hardware now, and early access signups are open.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-6">
          <a href="https://mylegacytape.com" target="_blank" rel="noopener noreferrer" class="link">
            Visit mylegacytape.com ↗
          </a>
          <span class="font-mono text-xs uppercase tracking-[0.15em] text-faint">Now prototyping</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="scroll-mt-24 border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div data-reveal>
        <p class="eyebrow">Services</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">What we do</h2>
      </div>

      <div class="mt-12 grid gap-12 md:grid-cols-3 md:gap-10">
        <div data-reveal>
          <svg width="56" height="56" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <g stroke="var(--color-ink)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9,13 C8,26 9,40 8,51 L56,51 C55,38 56,24 56,13 Z"></path>
              <path d="M8,22 L56,22" stroke-width="1.8"></path>
              <path d="M14,30 L40,30" stroke-width="1.8" opacity="0.6"></path>
              <path d="M14,38 L48,38" stroke-width="1.8" opacity="0.6"></path>
              <path d="M14,45 L32,45" stroke-width="1.8" opacity="0.6"></path>
            </g>
            <circle cx="14.5" cy="17.5" r="1.9" fill="var(--color-accent)"></circle>
            <circle cx="21" cy="17.5" r="1.9" fill="var(--color-accent)"></circle>
          </svg>
          <h3 class="mt-5 text-2xl font-medium">Websites</h3>
          <p class="mt-3 text-soft">
            Marketing sites, storefronts, menus, booking pages. Built to load fast, read well on a
            phone, and be easy to keep current.
          </p>
          <ul class="mt-5 text-sm text-soft">
            <li class="border-t border-line py-2.5">Design and build</li>
            <li class="border-t border-line py-2.5">Online stores</li>
            <li class="border-t border-line py-2.5">SEO basics done properly</li>
          </ul>
        </div>

        <div data-reveal style="--reveal-delay: 0.08s">
          <svg width="56" height="56" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <g stroke="var(--color-ink)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21,7 C20,24 21,42 20,57 L43,57 C44,41 43,22 44,7 Z"></path>
              <path d="M28,12 L36,12" stroke-width="1.8"></path>
              <path d="M28,51 L36,51" stroke-width="1.8"></path>
            </g>
            <g stroke="var(--color-ink)" stroke-width="1.8">
              <circle cx="27" cy="25" r="2.6"></circle>
              <circle cx="37" cy="35" r="2.6"></circle>
            </g>
            <circle cx="37" cy="25" r="2.6" fill="var(--color-accent)"></circle>
            <circle cx="27" cy="35" r="2.6" fill="var(--color-accent)"></circle>
          </svg>
          <h3 class="mt-5 text-2xl font-medium">Apps</h3>
          <p class="mt-3 text-soft">
            iOS and web apps for when a website isn't enough. We handle design, development, and
            the App Store release.
          </p>
          <ul class="mt-5 text-sm text-soft">
            <li class="border-t border-line py-2.5">iPhone apps</li>
            <li class="border-t border-line py-2.5">Web apps</li>
            <li class="border-t border-line py-2.5">App Store submission</li>
          </ul>
        </div>

        <div data-reveal style="--reveal-delay: 0.16s">
          <svg width="56" height="56" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <g stroke="var(--color-ink)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22,30 C20,40 21,48 26,50 L44,50 C49,48 50,38 48,30 Z"></path>
              <path d="M26,30 C28,20 42,20 44,30" stroke-width="2"></path>
              <path d="M22,33 L10,22 L14,18 L25,30" stroke-width="2"></path>
            </g>
            <g stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round">
              <path d="M9,28 L8,32"></path>
              <path d="M13,30 L11,35"></path>
              <path d="M6,24 L4,27"></path>
            </g>
          </svg>
          <h3 class="mt-5 text-2xl font-medium">Ongoing help</h3>
          <p class="mt-3 text-soft">
            After launch we stick around if you want us to. Hosting, content changes, integrations,
            and a person who answers email.
          </p>
          <ul class="mt-5 text-sm text-soft">
            <li class="border-t border-line py-2.5">Hosting and updates</li>
            <li class="border-t border-line py-2.5">Small changes, handled quickly</li>
            <li class="border-t border-line py-2.5">Third-party integrations</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="process" class="scroll-mt-24 border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div data-reveal>
        <p class="eyebrow">Process</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">How a project runs</h2>
        <p class="mt-4 max-w-2xl text-soft">
          Five steps, no mystery. You know what's happening at every stage, and nothing goes live
          until you've signed off on it.
        </p>
      </div>

      <ol class="mt-12 border-t border-line">
        {
          steps.map((step, i) => (
            <li
              class="grid grid-cols-[4rem_1fr] gap-x-4 gap-y-2 border-b border-line py-7 md:grid-cols-[5rem_14rem_1fr] md:gap-6"
              data-reveal
              style={`--reveal-delay: ${i * 0.05}s`}
            >
              <span class="relative inline-flex h-12 w-12 items-center justify-center">
                <svg class="absolute inset-0 h-full w-full" viewBox="0 0 56 56" fill="none" aria-hidden="true">
                  <path
                    d="M28,6 C44,4 52,16 50,30 C48,44 36,52 24,50 C10,48 4,36 8,22 C11,11 18,7 28,6 Z"
                    stroke="var(--color-ink)"
                    stroke-width="2"
                  />
                  <path
                    d="M28,6 C44,4 52,16 50,30 C48,44 36,52 24,50 C10,48 4,36 8,22 C11,11 18,7 28,6 Z"
                    stroke="var(--color-ink)"
                    stroke-width="1.2"
                    opacity="0.25"
                    transform="rotate(7 28 28)"
                  />
                </svg>
                <span class="font-display text-lg font-medium">{step.n}</span>
              </span>
              <h3 class="self-center text-xl font-medium">{step.title}</h3>
              <p class="col-span-2 text-soft md:col-span-1 md:self-center">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="scroll-mt-24 border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div class="grid gap-10 md:grid-cols-2 md:gap-16">
        <div data-reveal>
          <p class="eyebrow">About</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">Small on purpose.</h2>
        </div>
        <div class="space-y-5 text-soft md:pt-12" data-reveal style="--reveal-delay: 0.08s">
          <p>
            FutureClarity is a deliberately small studio. The person you talk to on the first call
            is the person who designs and builds your project. No account managers, no hand-offs,
            no ticket queue.
          </p>
          <p>
            We work mostly with small businesses: shops, restaurants, local services. At that size
            a website has one job, bringing in customers, so we keep our builds simple, fast, and
            easy for you to update. If something would add cost without adding customers, we'll
            tell you to skip it.
          </p>
          <p>
            Between client projects we build products of our own. LegacyTape, our recording
            device for preserving family stories, is the current one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="scroll-mt-24">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div class="relative grid gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16">
        <div data-reveal>
          <p class="eyebrow">Contact</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            Tell us what you're working on.
          </h2>
          <p class="mt-4 text-soft">
            Email, call, or use the form. We read everything and usually reply within a business
            day, with honest advice and a realistic quote.
          </p>

          <dl class="mt-10 space-y-6">
            <div>
              <dt class="font-mono text-xs uppercase tracking-[0.15em] text-faint">Email</dt>
              <dd class="mt-1">
                <a href="mailto:futureclaritytechnologies@gmail.com" class="link break-all">
                  futureclaritytechnologies@gmail.com
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-mono text-xs uppercase tracking-[0.15em] text-faint">Phone</dt>
              <dd class="mt-1"><a href="tel:+18185850475" class="link">+1 (818) 585-0475</a></dd>
            </div>
          </dl>

          <svg
            class="mt-10 hidden h-20 w-28 md:block"
            viewBox="0 0 120 90"
            fill="none"
            aria-hidden="true"
          >
            <g stroke="var(--color-ink)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.55">
              <path d="M10,14 C52,8 88,30 100,66"></path>
              <path d="M86,62 L101,68 L104,51"></path>
            </g>
          </svg>
        </div>

        <form
          action="https://formspree.io/f/movkledr"
          method="POST"
          class="space-y-5 border border-line bg-card p-6 sm:p-8"
          data-reveal
          style="--reveal-delay: 0.08s"
        >
          <div>
            <label for="name" class="mb-1.5 block text-sm font-medium">Name</label>
            <input type="text" id="name" name="name" required class="field" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium">Email</label>
            <input type="email" id="email" name="email" required class="field" placeholder="you@example.com" />
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium">Message</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="field resize-none"
              placeholder="What are you building, and when do you need it?"></textarea>
          </div>
          <button type="submit" class="btn w-full sm:w-auto">Send message</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // Links from other pages arrive as /?scroll=<section-id>
    window.addEventListener('load', function () {
      const scrollTo = new URLSearchParams(window.location.search).get('scroll');

      if (scrollTo) {
        const target = document.getElementById(scrollTo);
        if (target) {
          setTimeout(() => {
            target.scrollIntoView({ behavior: 'smooth' });
            window.history.replaceState({}, document.title, window.location.pathname);
          }, 100);
        }
      }
    });

    // Floating preview that trails the cursor over the work list.
    // Mouse only: skipped entirely on touch devices.
    (function () {
      const box = document.getElementById('work-preview');
      const img = box?.querySelector('img');
      if (!box || !img || !window.matchMedia('(pointer: fine)').matches) return;

      let raf = 0;
      const W = 300;
      const H = 225;
      const PAD = 16;

      function follow(e: MouseEvent) {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          let x = e.clientX + 28;
          let y = e.clientY - H / 2;
          if (x + W + PAD > window.innerWidth) x = e.clientX - W - 28;
          y = Math.max(PAD, Math.min(y, window.innerHeight - H - PAD));
          if (box) {
            box.style.left = x + 'px';
            box.style.top = y + 'px';
          }
        });
      }

      document.querySelectorAll<HTMLElement>('[data-preview]').forEach((row) => {
        row.addEventListener('mouseenter', () => {
          if (img && row.dataset.preview) img.src = row.dataset.preview;
          box.classList.toggle('contain', row.dataset.fit === 'contain');
          box.classList.add('active');
        });
        row.addEventListener('mouseleave', () => box.classList.remove('active'));
        row.addEventListener('mousemove', follow);
      });
    })();
  </script>
</Layout>
