/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Content-hashed build assets never change at a given URL — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Icons: cache for a day but always allow updates. (Previously this was a
# full year with no revalidation, which is why an old favicon could stick.)
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
/favicon-96.png
  Cache-Control: public, max-age=86400, must-revalidate
/favicon-192.png
  Cache-Control: public, max-age=86400, must-revalidate
/apple-touch-icon.png
  Cache-Control: public, max-age=86400, must-revalidate

# HTML pages must always revalidate so a new deploy shows immediately and the
# browser never serves a stale page (incl. the clean-URL routes).
/
  Cache-Control: public, max-age=0, must-revalidate
/portfolio
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
